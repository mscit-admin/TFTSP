# apps/api local env — copy to .env (the repo root .env is also read by docker compose).
# App connects with tftsp_app (NO BYPASSRLS). Migrations/seed/platform aggregates use the owner role.
DATABASE_URL="postgresql://tftsp_app:tftsp_app_pw@localhost:5432/tftsp?schema=public"
DATABASE_MIGRATION_URL="postgresql://tftsp:tftsp_dev_pw@localhost:5432/tftsp?schema=public"

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Account lockout policy (Spec Section 3 / M1)
AUTH_MAX_FAILED_ATTEMPTS="5"
AUTH_LOCK_MINUTES="15"
AUTH_MIN_PASSWORD_LENGTH="12"

# Duplicate pre-check similarity threshold (Spec Section 8)
DUPLICATE_SIMILARITY_THRESHOLD="0.6"

API_PORT="3000"
NODE_ENV="development"
LOG_LEVEL="info"
DEFAULT_LOCALE="ar"

# ---- M2: Redis / BullMQ (scheduled expiry jobs) ----
REDIS_HOST="localhost"
REDIS_PORT="6379"
# Set to "false" to skip the BullMQ scheduler (e.g. Redis unavailable / in tests).
ENABLE_SCHEDULER="true"

# ---- M2: Email (MailHog in dev) — used by the notification email channel ----
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="no-reply@tftsp.local"
