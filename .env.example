# ---- Database ----
# App connects with a role that does NOT have BYPASSRLS (see Section 4). Migrations may use the owner role.
DATABASE_URL="postgresql://tftsp_app:tftsp_app_pw@localhost:5432/tftsp?schema=public"
DATABASE_MIGRATION_URL="postgresql://tftsp:tftsp_dev_pw@localhost:5432/tftsp?schema=public"

# ---- Redis / BullMQ ----
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ---- MinIO (S3-compatible) ----
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_USE_SSL="false"
MINIO_BUCKET="tftsp"

# ---- Mail (MailHog in dev) ----
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="no-reply@tftsp.local"

# ---- JWT ----
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ---- App ----
API_PORT="3000"
NODE_ENV="development"

# ---- Gateway (single entry port for the whole system) ----
TFTSP_PORT="8080"

# ---- Public host (server public IP / hostname) ----
# Used to sign browser-reachable document/photo URLs (MinIO presign) and as the
# app's public address. Set to your server's PUBLIC IP for a bare-IP deployment.
PUBLIC_HOST="localhost"
